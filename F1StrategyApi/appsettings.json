{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "f1strategylab"
  },
  "ExternalApis": {
    "JolpicaBaseUrl": "https://api.jolpi.ca/ergast/",
    "OpenF1BaseUrl":  "https://api.openf1.org/v1/",
    "WeatherBaseUrl": "https://api.open-meteo.com/v1/"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:4173"
    ]
  },
  "Cache": {
    "CalendarTtlHours":   24,
    "WeatherTtlMinutes":   5,
    "TelemetryTtlMinutes": 10,
    "StandingsTtlMinutes": 15,
    "PitStopTtlMinutes":   30
  }
}
